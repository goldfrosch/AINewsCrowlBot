# .env and data/ must never enter the image — they contain secrets and runtime DB

# version control / project metadata
.git
.github
.sisyphus

# Claude runtime prompts are required by agents/news_curation_agent.py.
# Keep agent/skill markdown, but exclude local Claude app settings and project notes.
.claude/*
!.claude/agents/
!.claude/agents/**
!.claude/skills/
!.claude/skills/**
.claude/settings*.json
.claude/project/

# Python caches / virtualenvs
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv
venv/

# env / secrets / runtime data
.env
.env.*
data/

# tests / docs / misc
tests/
docs/
*.md
*.log
.DS_Store

# Re-include Claude runtime markdown after the global *.md exclusion above.
!.claude/agents/
!.claude/agents/**
!.claude/skills/
!.claude/skills/**

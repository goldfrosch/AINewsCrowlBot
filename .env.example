# ── Discord ───────────────────────────────────────
# 봇 토큰: Discord Developer Portal > Bot > Token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# 기사를 게시할 채널 ID (채널 우클릭 > ID 복사)
DISCORD_CHANNEL_ID=123456789012345678

# 예외 아이디로 관리자가 아니더라도 조정할 수 있는 하드코딩 id
ALLOWED_USER_IDS=

# ── Anthropic / Claude (주 리서치 엔진) ───────────
# https://console.anthropic.com/settings/keys
# 설정하면 Claude 웹 리서치로 뉴스 큐레이션 (권장)
# 미설정 시 기존 크롤러로 폴백
ANTHROPIC_API_KEY=

# 사용할 Claude 모델 (기본값: claude-sonnet-4-6)
# 선택지: claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# ── YouTube ───────────────────────────────────────
# Google Cloud Console > YouTube Data API v3 > API 키
# 없으면 YouTube 크롤링 스킵됨
YOUTUBE_API_KEY=

# ── Reddit ────────────────────────────────────────
# https://www.reddit.com/prefs/apps 에서 script 앱 생성
# 없으면 비인증 공개 JSON API로 폴백 (대부분 동작함)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AINewsCrawlBot/1.0 by YourUsername

# ── Threads ───────────────────────────────────────
# Meta Developer > Threads API > OAuth 2.0 액세스 토큰
# https://developers.facebook.com/docs/threads
# 없으면 Threads 크롤링 스킵됨
THREADS_ACCESS_TOKEN=

# ── LinkedIn ──────────────────────────────────────
# LinkedIn 공식 API는 기업용으로 제한적.
# 아래 쿠키 값을 브라우저에서 복사하면 스크래핑 시도 (불안정)
# 없으면 LinkedIn 크롤링 스킵됨
LINKEDIN_LI_AT=